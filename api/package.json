{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0"
  },
  "_moduleAliases": {
    "@": "dist",
    "@config": "dist/config",
    "@lib": "dist/lib",
    "@plugins": "dist/plugins",
    "@modules": "dist/modules",
    "@common": "dist/common"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma",
    "db:generate:postgres": "prisma generate --schema prisma-postgres/schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:deploy:postgres": "prisma migrate deploy --schema prisma-postgres/schema.prisma",
    "db:migrate:sqlite-to-postgres": "npm run db:generate:sqlite && npm run db:generate:postgres && tsx prisma/migrate-sqlite-to-postgres.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.10.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "firebase-admin": "^13.8.0",
    "module-alias": "^2.3.4",
    "pino": "^8.19.0",
    "prisma": "^5.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.11.0",
    "eslint": "^8.57.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
