generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== CORE USER ====================
// Role values: PLAYER, COACH, OPERATOR, ADMIN
// Status values: ACTIVE, PENDING, SUSPENDED

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  avatar    String?
  role      String   @default("PLAYER")
  status    String   @default("ACTIVE")
  emailVerified Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  wallet            Wallet?
  preferences       UserPreference?
  refreshTokens     RefreshToken[]
  bookings          Booking[]
  paymentIntents    PaymentIntent[]
  teamPostsCreated  TeamPost[]
  teamPostMembers   TeamPostMember[]
  joinRequests      TeamPostJoinRequest[]
  storeOrders       StoreOrder[]
  notifications     Notification[]
  reviews           Review[]
  favorites         Favorite[]
  roleUpgradeRequests RoleUpgradeRequest[]
  auditLogs         AuditLog[]
  
  // Coach/Operator specific
  coachProfile      Coach?
  operatorFacility  Facility?
  
  @@index([email])
  @@index([role])
  @@index([status])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([token])
  @@index([userId])
}

model UserPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  
  // Localization
  language              String   @default("en")
  currency              String   @default("EGP")
  timezone              String   @default("Africa/Cairo")
  rtl                   Boolean  @default(false)
  
  // Notifications
  emailNotifications    Boolean  @default(true)
  pushNotifications     Boolean  @default(true)
  smsNotifications      Boolean  @default(false)
  
  // Privacy
  profileVisible        Boolean  @default(true)
  showActivityStatus    Boolean  @default(true)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== SPORTS & FACILITIES ====================
// SportType values: TENNIS, PADEL, FOOTBALL, SQUASH, BASKETBALL, BADMINTON

model Sport {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  icon        String?
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  facilities  FacilitySport[]
  courts      Court[]
  coaches     Coach[]
}

model Facility {
  id          String   @id @default(cuid())
  name        String
  description String?
  logo        String?
  address     String?
  city        String
  country     String   @default("Egypt")
  phone       String?
  email       String?
  
  status      String   @default("PENDING")
  
  // Owner relation
  operatorId  String   @unique
  operator    User     @relation(fields: [operatorId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  branches    Branch[]
  sports      FacilitySport[]
  products    StoreProduct[]
  reviews     Review[]
  favorites   Favorite[]
  
  @@index([operatorId])
  @@index([status])
}

model FacilitySport {
  id          String   @id @default(cuid())
  facilityId  String
  sportId     String
  
  facility    Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  sport       Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  
  @@unique([facilityId, sportId])
}

model Branch {
  id          String   @id @default(cuid())
  facilityId  String
  name        String
  address     String
  city        String
  phone       String?
  
  facility    Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  courts      Court[]
  
  @@index([facilityId])
}

// ==================== COURTS ====================

model Court {
  id          String   @id @default(cuid())
  branchId    String
  sportId     String
  
  name        String
  description String?
  images      String   @default("[]") // JSON array stored as string
  
  // Features
  indoor      Boolean  @default(false)
  hasLighting Boolean  @default(false)
  hasParking  Boolean  @default(false)
  
  // Pricing
  basePrice   Decimal  @default(0)
  currency    String   @default("EGP")
  
  status      String   @default("ACTIVE")
  
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sport       Sport    @relation(fields: [sportId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  pricingRules CourtPricingRule[]
  closures    CourtClosure[]
  bookings    Booking[]
  teamPosts   TeamPost[]
  favorites   Favorite[]
  reviews     Review[]
  
  @@index([branchId])
  @@index([sportId])
  @@index([status])
}

model CourtPricingRule {
  id          String   @id @default(cuid())
  courtId     String
  
  dayOfWeek   Int?
  startHour   Int
  endHour     Int
  
  price       Decimal
  isPeak      Boolean  @default(false)
  
  court       Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([courtId])
}

model CourtClosure {
  id          String   @id @default(cuid())
  courtId     String
  
  date        DateTime
  reason      String?
  allDay      Boolean  @default(true)
  startHour   Int?
  endHour     Int?
  
  court       Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([courtId, date])
  @@index([courtId])
}

// ==================== COACHES ====================

model Coach {
  id              String   @id @default(cuid())
  userId          String   @unique
  
  slug            String   @unique
  bio             String?
  experienceYears Int      @default(0)
  certifications  String   @default("[]") // JSON array
  specialties     String   @default("[]") // JSON array
  
  sessionRate     Decimal  @default(0)
  currency        String   @default("EGP")
  commissionRate  Decimal  @default(20)
  
  isActive        Boolean  @default(true)
  isVerified      Boolean  @default(false)
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport           Sport    @relation(fields: [sportId], references: [id])
  sportId         String
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  services        CoachService[]
  availability    CoachAvailability[]
  availabilityExceptions CoachAvailabilityException[]
  bookings        Booking[]
  favorites       Favorite[]
  reviews         Review[]
  
  @@index([userId])
  @@index([slug])
  @@index([sportId])
  @@index([isActive])
}

model PaymentIntent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  
  amount      Decimal
  currency    String   @default("EGP")
  
  paymentMethod String
  status      String   @default("PENDING")
  paymentRef  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([bookingId])
  @@index([status])
}

model CoachService {
  id          String   @id @default(cuid())
  coachId     String
  
  name        String
  description String?
  duration    Int
  price       Decimal
  currency    String   @default("EGP")
  isActive    Boolean  @default(true)
  
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([coachId])
}

model CoachAvailability {
  id          String   @id @default(cuid())
  coachId     String
  
  dayOfWeek   Int
  startHour   Int
  endHour     Int
  
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([coachId, dayOfWeek, startHour])
  @@index([coachId])
}

model CoachAvailabilityException {
  id          String   @id @default(cuid())
  coachId     String
  
  date        DateTime
  isAvailable Boolean  @default(false)
  reason      String?
  
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([coachId, date])
  @@index([coachId])
}

// ==================== BOOKINGS ====================
// BookingStatus: PENDING, CONFIRMED, COMPLETED, CANCELLED, NO_SHOW
// BookingType: COURT, COACH
// PaymentStatus: PENDING, PAID, REFUNDED, FAILED

model Booking {
  id              String   @id @default(cuid())
  
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  type            String   @default("COURT")
  status          String   @default("PENDING")
  
  courtId         String?
  court           Court?   @relation(fields: [courtId], references: [id])
  
  coachId         String?
  coach           Coach?   @relation(fields: [coachId], references: [id])
  coachServiceId  String?
  
  date            DateTime
  startHour       Int
  endHour         Int
  duration        Int
  
  playerCount     Int      @default(1)
  
  basePrice       Decimal
  discount        Decimal  @default(0)
  couponId        String?
  totalPrice      Decimal
  currency        String   @default("EGP")
  
  paymentStatus   String   @default("PENDING")
  paymentMethod   String?
  paymentRef      String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  cancelledAt     DateTime?
  cancellationReason String?
  
  review          Review?
  paymentIntents  PaymentIntent[]
  
  @@index([userId])
  @@index([courtId])
  @@index([coachId])
  @@index([status])
  @@index([date])
  @@index([paymentStatus])
}

// ==================== TEAMS ====================
// TeamPostStatus: OPEN, FULL, CANCELLED
// JoinRequestStatus: PENDING, APPROVED, REJECTED

model TeamPost {
  id              String   @id @default(cuid())
  
  createdByUserId String
  createdBy       User     @relation(fields: [createdByUserId], references: [id])
  
  courtId         String
  court           Court    @relation(fields: [courtId], references: [id])
  
  date            DateTime
  startHour       Int
  endHour         Int
  
  neededPlayers   Int
  memberUserIds   String   @default("[]") // JSON array
  
  status          String   @default("OPEN")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  members         TeamPostMember[]
  joinRequests    TeamPostJoinRequest[]
  
  @@index([courtId])
  @@index([date])
  @@index([status])
  @@index([createdByUserId])
}

model TeamPostMember {
  id          String   @id @default(cuid())
  teamPostId  String
  userId      String
  
  joinedAt    DateTime @default(now())
  
  teamPost    TeamPost @relation(fields: [teamPostId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([teamPostId, userId])
  @@index([teamPostId])
  @@index([userId])
}

model TeamPostJoinRequest {
  id          String   @id @default(cuid())
  teamPostId  String
  userId      String
  
  status      String   @default("PENDING")
  requestedAt DateTime @default(now())
  respondedAt DateTime?
  
  teamPost    TeamPost @relation(fields: [teamPostId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([teamPostId, userId])
  @@index([teamPostId])
  @@index([userId])
}

// ==================== STORE ====================
// ProductStatus: IN_STOCK, LOW_STOCK, OUT_OF_STOCK
// OrderStatus: PENDING, PROCESSING, DELIVERED, CANCELLED
// OrderFulfillment: PICKUP, DELIVERY

model StoreProduct {
  id          String   @id @default(cuid())
  
  facilityId  String
  facility    Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  category    String
  images      String   @default("[]") // JSON array
  
  price       Decimal
  currency    String   @default("EGP")
  
  quantity    Int      @default(0)
  status      String   @default("IN_STOCK")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  orderItems  StoreOrderItem[]
  favorites   Favorite[]
  
  @@index([facilityId])
  @@index([category])
  @@index([status])
}

model StoreOrder {
  id              String   @id @default(cuid())
  
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  subtotal        Decimal
  discount        Decimal  @default(0)
  deliveryFee     Decimal  @default(0)
  total           Decimal
  currency        String   @default("EGP")
  
  fulfillment     String   @default("PICKUP")
  status          String   @default("PENDING")
  
  deliveryAddress String?
  contactPhone    String?
  
  paymentStatus   String   @default("PENDING")
  paymentMethod   String?
  paymentRef      String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  items           StoreOrderItem[]
  
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
}

model StoreOrderItem {
  id          String   @id @default(cuid())
  
  orderId     String
  order       StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId   String
  product     StoreProduct @relation(fields: [productId], references: [id])
  
  quantity    Int
  unitPrice   Decimal
  totalPrice  Decimal
  
  @@index([orderId])
  @@index([productId])
}

// ==================== WALLET ====================
// TransactionType: CREDIT, DEBIT
// TransactionStatus: PENDING, COMPLETED, FAILED

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  
  balance     Decimal  @default(0)
  currency    String   @default("EGP")
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  
  type        String   @default("CREDIT")
  amount      Decimal
  currency    String   @default("EGP")
  
  description String?
  referenceType String?
  referenceId String?
  
  status      String   @default("COMPLETED")
  
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([walletId])
  @@index([referenceType, referenceId])
}

// ==================== COUPONS ====================
// CouponType: PERCENTAGE, FIXED_AMOUNT
// CouponStatus: ACTIVE, EXPIRED, DRAFT

model Coupon {
  id          String   @id @default(cuid())
  
  code        String   @unique
  description String?
  
  type        String   @default("PERCENTAGE")
  value       Decimal
  
  minOrderValue Decimal? 
  maxDiscount   Decimal?
  
  startDate   DateTime @default(now())
  endDate     DateTime
  
  usageLimit  Int?
  usageCount  Int      @default(0)
  perUserLimit Int     @default(1)
  
  status      String   @default("ACTIVE")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([code])
  @@index([status])
  @@index([endDate])
}

// ==================== NOTIFICATIONS ====================
// NotificationType: BOOKING_CONFIRMED, BOOKING_CANCELLED, TEAM_JOIN_REQUEST, TEAM_APPROVED, TEAM_REJECTED, TEAM_FULL, PAYMENT_RECEIVED, PAYMENT_FAILED, VERIFICATION_APPROVED, VERIFICATION_REJECTED, SYSTEM

model Notification {
  id          String   @id @default(cuid())
  userId      String
  
  type        String   @default("SYSTEM")
  title       String
  message     String
  
  referenceType String?
  referenceId   String?
  
  isRead      Boolean  @default(false)
  readAt      DateTime?
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ==================== REVIEWS ====================
// ReviewTargetType: FACILITY, COURT, COACH
// ReviewStatus: PENDING, APPROVED, REJECTED

model Review {
  id          String   @id @default(cuid())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  targetType  String   @default("COURT")
  facilityId  String?
  courtId     String?
  coachId     String?
  
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id])
  
  rating      Int
  comment     String?
  
  status      String   @default("PENDING")
  moderationReason String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  facility    Facility? @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  court       Court?    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  coach       Coach?    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  
  @@unique([userId, bookingId])
  @@index([userId])
  @@index([targetType])
  @@index([facilityId])
  @@index([courtId])
  @@index([coachId])
  @@index([status])
}

// ==================== ROLE UPGRADE ====================
// UpgradeRequestStatus: PENDING, APPROVED, REJECTED

model RoleUpgradeRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  requestedRole String   @default("COACH")
  
  sportId     String?
  experienceYears Int?
  bio         String?
  
  businessName String?
  businessAddress String?
  licenseNumber String?
  
  documents   String   @default("[]") // JSON array
  
  status      String   @default("PENDING")
  
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewerId  String?
  notes       String?
  
  @@index([userId])
  @@index([status])
  @@index([requestedRole])
}

// ==================== FAVORITES ====================

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  courtId     String?
  court       Court?   @relation(fields: [courtId], references: [id], onDelete: Cascade)
  
  coachId     String?
  coach       Coach?   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  
  facilityId  String?
  facility    Facility? @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  
  productId   String?
  product     StoreProduct? @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, courtId])
  @@unique([userId, coachId])
  @@unique([userId, facilityId])
  @@unique([userId, productId])
  @@index([userId])
}

// ==================== AUDIT LOGS ====================
// AuditAction: CREATE, UPDATE, DELETE, LOGIN, LOGOUT, VERIFY, APPROVE, REJECT
// AuditSeverity: INFO, WARNING, CRITICAL

model AuditLog {
  id          String   @id @default(cuid())
  
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  
  action      String   @default("CREATE")
  object      String
  details     String?  @default("{}") // JSON string
  
  ip          String?
  userAgent   String?
  
  severity    String   @default("INFO")
  
  createdAt   DateTime @default(now())
  
  @@index([actorId])
  @@index([action])
  @@index([object])
  @@index([createdAt])
  @@index([severity])
}

// ==================== CMS ====================

model CmsContent {
  id          String   @id @default(cuid())
  
  page        String
  language    String   @default("en")
  
  title       String
  content     String
  
  status      String   @default("DRAFT")
  version     String   @default("1.0")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([page, language])
  @@index([page])
  @@index([status])
}
