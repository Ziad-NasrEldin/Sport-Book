# Copy to .env on VPS. Replace every placeholder before starting containers.

# Public domain
DOMAIN=sportbook.example.com
NEXT_PUBLIC_SITE_URL=https://sportbook.example.com
NEXT_PUBLIC_API_URL=/api/v1
WEB_ORIGIN=https://sportbook.example.com

# API runtime
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# SQLite production database stored in Docker volume sportbook-data.
# PostgreSQL requires changing api/prisma/schema.prisma provider first.
DATABASE_URL=file:/data/sportbook.db

# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=7

# SMTP email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=replace-with-smtp-password

# Paymob
PAYMOB_API_KEY=replace-with-paymob-api-key
PAYMOB_INTEGRATION_ID=replace-with-paymob-integration-id
PAYMOB_HMAC_SECRET=replace-with-paymob-hmac-secret
